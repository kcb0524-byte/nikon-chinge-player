{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "volumes",
  "description": "외장드라이브 접근 권한",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "/Volumes/**" }]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "/Volumes/**" }]
    }
  ]
}
