{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nikon-chinge-music-player",
  "version": "0.1.0",
  "identifier": "com.nikonchinge.musicplayer",
  "build": {
    "frontendDist": "../front"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "니콘 친게 뮤직 플레이어",
        "width": 1280,
        "height": 1060,
        "minWidth": 960,
        "minHeight": 920,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}